# Copy to `.env.local` and fill in to use the Supabase backend.
# Leave VITE_DATA_SOURCE unset (or =local) to run the self-contained prototype.

VITE_DATA_SOURCE=supabase
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# The service-role key is NEVER used in the client. Keep it only in
# Supabase Edge Function secrets (e.g. the expiry cron).
